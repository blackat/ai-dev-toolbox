# .env — never commit this file to git
ANTHROPIC_API_KEY=           # leave empty when using Ollama
OLLAMA_MODEL=qwen3-coder:30b-a3b

# For Mac: Ollama runs on host, container connects here
# For Linux/Windows with GPU: change to http://ollama:11434
OLLAMA_HOST=http://host.docker.internal:11434

# Workspace, where your code base resides, change it according to your requirements
MY_WORKSPACE=./workspace