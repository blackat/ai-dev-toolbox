# .env — never commit this file to git

# Claude Code
# Set a token (ANTHROPIC_AUTH_TOKEN) or an API key (ANTHROPIC_API_KEY) not both
ANTHROPIC_API_KEY=ollama                                        # leave empty when using Ollama
ANTHROPIC_BASE_URL=http://host.docker.internal:11434            # ollama server
CLAUDE_CODE_SKIP_CONFIRMATION=true

# Ollama
OLLAMA_MODEL=qwen3-coder:30b                                    # default model

# For Mac: Ollama runs on host, container connects here
# For Linux/Windows with GPU: change to http://ollama:11434
OLLAMA_HOST=http://host.docker.internal:11434

# Workspace, where your code base resides, change it 
# according to your requirements
MY_WORKSPACE=/Users/blackat/Development/Github/ai-dev-test      # set your own workspace